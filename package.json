{
  "name": "@alexify/kerberos",
  "version": "2.0.0",
  "description": "Fast and low overhead authorization framework for JavaScript runtime",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./tests": {
      "types": "./tests.d.ts",
      "default": "./tests.js"
    }
  },
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "lint": "eslint src -c eslint.config.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alexis-Technologies/kerberos.git"
  },
  "keywords": [
    "kerberos",
    "authorization",
    "authentication",
    "security",
    "auth",
    "policy",
    "access control",
    "cerbos",
    "framework",
    "schema",
    "web"
  ],
  "author": "Alex Dolid <dolid.sasha@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Alexis-Technologies/kerberos/issues"
  },
  "homepage": "https://alexis.dev",
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@jsep-plugin/new": "^1.0.4",
    "@jsep-plugin/object": "^1.2.2",
    "@jsep-plugin/ternary": "^1.1.4",
    "@sinclair/typebox": "^0.34.48",
    "@stylistic/eslint-plugin-js": "^2.10.1",
    "ajv": "^8.18.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.8.3",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-unicorn": "^56.0.0",
    "globals": "^15.11.0",
    "jsep": "^1.4.0",
    "keyv": "^5.6.0",
    "neostandard": "^0.11.7",
    "pino": "^10.3.1",
    "prettier": "^3.3.3",
    "zod": "^4.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "pre-commit": [
    "lint",
    "test"
  ],
  "packageManager": "pnpm@10.10.0",
  "files": [
    "index.js",
    "index.d.ts",
    "tests.js",
    "tests.d.ts",
    "src/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "package.json",
    "pnpm-lock.yaml"
  ]
}
